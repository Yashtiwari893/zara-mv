{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization, x-cron-secret" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reminders?secret=${CRON_SECRET}",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/briefing?secret=${CRON_SECRET}",
      "schedule": "30 2 * * *"
    }
  ],
  "functions": {
    "src/app/api/webhook/whatsapp/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/reminders/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/briefing/route.ts": {
      "maxDuration": 60
    }
  }
}

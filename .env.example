# =========================================
# ZARA — Environment Variables
# Copy to .env.local and fill in your values
# =========================================

# ─── Core App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
BOT_NAME=11za Personal Assistant

# ─── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── 11za WhatsApp API ─────────────────────────────────────────
ELEVEN_ZA_API_KEY=your-11za-api-key
WHATSAPP_AUTH_TOKEN=your-11za-auth-token
WHATSAPP_ORIGIN=https://your-website.com

# ─── Webhook Verification ──────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=any-random-secret-string

# ─── AI APIs     ───────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
MISTRAL_API_KEY=your-mistral-api-key

# ─── Google OAuth (for Document Vault / Drive) ─────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/api/auth/google/callback

# ─── Security ──────────────────────────────────────────────────
CRON_SECRET=random-secret-for-cron-endpoints
DEV_SECRET=random-secret-for-dev-reset-endpoint

# ─── Optional Logging ─────────────────────────────────────────
# LOG_ENDPOINT=https://your-logging-service.com/ingest
